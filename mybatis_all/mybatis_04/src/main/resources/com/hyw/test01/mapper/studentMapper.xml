<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--映射文件,专门写sql语句的文件,映射成对象-->
<mapper namespace="com.hyw.test01.mapper.studentMapper">
    <select id="selectStudent" parameterType="map" resultType="student">
        select sid,sname,cid from t_student where sid = #{id}
    </select>

    <select id="selectAbout">
        select
            s.sid,s.sname,s.cid,c.cname
        from
            t_student s
        join
            t_class c
        on
            s.cid = c.cid
        where
            s.sid = #{id}
    </select>

</mapper>